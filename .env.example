# Supabase (main scanner app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (Defog widget dashboard - can be same or separate project)
NEXT_PUBLIC_DEFOG_SUPABASE_URL=https://your-defog-project.supabase.co
NEXT_PUBLIC_DEFOG_SUPABASE_ANON_KEY=your-defog-anon-key

# Alpha Vantage API (25 free calls/day)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Cron secret (to protect cron endpoints)
CRON_SECRET=your-random-secret-string
